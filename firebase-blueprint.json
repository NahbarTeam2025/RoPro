{
  "entities": {
    "Note": {
      "title": "Note",
      "description": "Rich-text note",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the note" },
        "content": { "type": "string", "description": "HTML content from TipTap" },
        "categoryId": { "type": "string", "description": "Category or tag name" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string", "description": "Owner userId" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["title", "content", "userId", "createdAt", "updatedAt"]
    },
    "Todo": {
      "title": "Todo",
      "description": "Task item",
      "type": "object",
      "properties": {
        "task": { "type": "string", "description": "Task description" },
        "dueDate": { "type": "string", "description": "Due date ISO string" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "completed": { "type": "boolean" },
        "categoryId": { "type": "string", "description": "Category ID" },
        "userId": { "type": "string", "description": "Owner userId" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["task", "priority", "completed", "userId", "createdAt", "updatedAt"]
    },
    "Link": {
      "title": "Link",
      "description": "URL bookmark",
      "type": "object",
      "properties": {
        "url": { "type": "string", "description": "URL of the link" },
        "title": { "type": "string", "description": "Title of the link" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "categoryId": { "type": "string", "description": "Category ID" },
        "userId": { "type": "string", "description": "Owner userId" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["url", "title", "userId", "createdAt", "updatedAt"]
    },
    "Prompt": {
      "title": "Prompt",
      "description": "User generated system prompt",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["title", "content", "category", "userId", "createdAt", "updatedAt"]
    },
    "Category": {
      "title": "Category",
      "description": "User generated taxonomy category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["note", "task", "link", "prompt", "household"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "type", "userId", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Household book entry",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "timestamp" },
        "userId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "isRecurring": { "type": "boolean" },
        "interval": { "type": "string", "enum": ["monthly", "yearly"] }
      },
      "required": ["description", "amount", "type", "category", "date", "userId", "createdAt"]
    },
    "Savings": {
      "title": "Savings",
      "description": "Total saved money",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["amount", "userId", "updatedAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Personal contact with birthday info",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "birthday": { "type": "string", "description": "ISO date string (YYYY-MM-DD)" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "userId", "createdAt", "updatedAt"]
    },
    "PasswordEntry": {
      "title": "PasswordEntry",
      "description": "Encrypted password storage",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Encrypted title/service name" },
        "username": { "type": "string", "description": "Encrypted username" },
        "password": { "type": "string", "description": "Encrypted password" },
        "url": { "type": "string", "description": "Encrypted login URL" },
        "note": { "type": "string", "description": "Encrypted note" },
        "category": { "type": "string", "description": "Encrypted category" },
        "userId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "username", "password", "userId", "createdAt", "updatedAt"]
    },
    "VaultConfig": {
      "title": "VaultConfig",
      "description": "Configuration for the encrypted vault",
      "type": "object",
      "properties": {
        "validationString": { "type": "string", "description": "Encrypted test string for password verification" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["validationString", "userId", "updatedAt"]
    },
    "Media": {
      "title": "Media",
      "description": "User uploaded media file metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "typ": { "type": "string", "enum": ["dokument", "bild", "video", "audio", "sonstiges"] },
        "kategorie": { "type": "string" },
        "storageUrl": { "type": "string" },
        "storagePath": { "type": "string" },
        "fileType": { "type": "string" },
        "fileSize": { "type": "number" },
        "userId": { "type": "string" },
        "uploadedAt": { "type": "timestamp" }
      },
      "required": ["name", "typ", "storageUrl", "storagePath", "fileType", "fileSize", "userId", "uploadedAt"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "User specific module configuration",
      "type": "object",
      "properties": {
        "modules": { "type": "array" }
      },
      "required": ["modules"]
    },
    "ShoppingListMeta": {
      "title": "ShoppingListMeta",
      "description": "Metadata for a shopping list",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "userId", "createdAt"]
    },
    "ShoppingListItem": {
      "title": "ShoppingListItem",
      "description": "An item in a shopping list",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "completed": { "type": "boolean" },
        "order": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "completed", "order", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/shoppinglists/{listId}": {
      "schema": { "$ref": "#/entities/ShoppingListMeta" },
      "description": "Stores shopping lists"
    },
    "/shoppinglists/{listId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/ShoppingListItem" },
      "description": "Stores items inside a shopping list"
    },
    "/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Stores user notes"
    },
    "/todos/{todoId}": {
      "schema": { "$ref": "#/entities/Todo" },
      "description": "Stores user tasks"
    },
    "/links/{linkId}": {
      "schema": { "$ref": "#/entities/Link" },
      "description": "Stores user bookmarks"
    },
    "/prompts/{promptId}": {
      "schema": { "$ref": "#/entities/Prompt" },
      "description": "Stores user prompts"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Stores user categories"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Stores household book transactions"
    },
    "/savings/{savingsId}": {
      "schema": { "$ref": "#/entities/Savings" },
      "description": "Stores total savings"
    },
    "/contacts/{contactId}": {
       "schema": { "$ref": "#/entities/Contact" },
       "description": "Stores user contacts"
    },
    "/passwords/{passwordId}": {
      "schema": { "$ref": "#/entities/PasswordEntry" },
      "description": "Stores encrypted passwords"
    },
    "/vaultConfigs/{configId}": {
      "schema": { "$ref": "#/entities/VaultConfig" },
      "description": "Stores vault configuration"
    },
    "/media/{fileId}": {
      "schema": { "$ref": "#/entities/Media" },
      "description": "Stores user media metadata"
    },
    "/userSettings/{userId}": {
      "schema": { "$ref": "#/entities/UserSettings" },
      "description": "Stores user settings for the dashboard"
    }
  }
}
